<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <!-- Initial seed values are handled in post_init_hook, but we can register reference templates here too -->
    <record id="badge_eco_warrior" model="ecosphere.badge">
      <field name="name">Eco Warrior</field>
      <field name="code">ECO-WARRIOR</field>
      <field name="description">Logged carbon offsets or reductions exceeding 1000kg CO2e.</field>
      <field name="category">carbon</field>
      <field name="badge_level">gold</field>
      <field name="xp_value">300</field>
      <field name="green_coins_value">60</field>
      <field name="icon_emoji">🏆</field>
    </record>

    <record id="badge_compliance_star" model="ecosphere.badge">
      <field name="name">Compliance Officer</field>
      <field name="code">COMP-STAR</field>
      <field name="description">Review all compliance issues assigned within 7 days.</field>
      <field name="category">compliance</field>
      <field name="badge_level">silver</field>
      <field name="xp_value">150</field>
      <field name="green_coins_value">30</field>
      <field name="icon_emoji">⭐</field>
    </record>
  </data>
</odoo>
