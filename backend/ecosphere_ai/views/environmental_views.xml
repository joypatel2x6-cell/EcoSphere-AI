<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Carbon Transaction Tree View -->
    <record id="view_carbon_transaction_tree" model="ir.ui.view">
      <field name="name">ecosphere.carbon.transaction.tree</field>
      <field name="model">ecosphere.carbon.transaction</field>
      <field name="arch" type="xml">
        <tree string="Carbon Transactions">
          <field name="name"/>
          <field name="transaction_date"/>
          <field name="department_id"/>
          <field name="emission_factor_id"/>
          <field name="quantity"/>
          <field name="unit"/>
          <field name="co2_kg"/>
          <field name="co2_tonnes"/>
          <field name="scope"/>
          <field name="state"/>
        </tree>
      </field>
    </record>

    <!-- Carbon Transaction Form View -->
    <record id="view_carbon_transaction_form" model="ir.ui.view">
      <field name="name">ecosphere.carbon.transaction.form</field>
      <field name="model">ecosphere.carbon.transaction</field>
      <field name="arch" type="xml">
        <form string="Carbon Transaction">
          <header>
            <button name="action_confirm" string="Confirm Entry" type="object" class="oe_highlight" states="draft"/>
            <button name="action_cancel" string="Cancel Entry" type="object" states="draft,confirmed"/>
            <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,audited"/>
          </header>
          <sheet>
            <div class="oe_title">
              <h1><field name="name"/></h1>
            </div>
            <group>
              <group>
                <field name="transaction_date"/>
                <field name="department_id"/>
                <field name="emission_factor_id"/>
                <field name="source_type"/>
              </group>
              <group>
                <field name="quantity"/>
                <field name="unit"/>
                <field name="co2_kg"/>
                <field name="co2_tonnes"/>
                <field name="scope"/>
                <field name="is_offset"/>
              </group>
            </group>
            <notebook>
              <page string="Audit &amp; Verification">
                <group>
                  <field name="verification_status"/>
                  <field name="user_id"/>
                </group>
              </page>
              <page string="Description">
                <field name="description" placeholder="Notes on calculation source..."/>
              </page>
            </notebook>
          </sheet>
          <div class="oe_chatter">
            <field name="message_follower_ids"/>
            <field name="activity_ids"/>
            <field name="message_ids"/>
          </div>
        </form>
      </field>
    </record>

    <!-- Goal Tree View -->
    <record id="view_environmental_goal_tree" model="ir.ui.view">
      <field name="name">ecosphere.environmental.goal.tree</field>
      <field name="model">ecosphere.environmental.goal</field>
      <field name="arch" type="xml">
        <tree string="Environmental Goals">
          <field name="name"/>
          <field name="goal_type"/>
          <field name="department_id"/>
          <field name="target_value"/>
          <field name="current_value"/>
          <field name="unit"/>
          <field name="progress_pct" widget="progressbar"/>
          <field name="deadline_date"/>
          <field name="state"/>
        </tree>
      </field>
    </record>

    <!-- Actions -->
    <record id="action_carbon_transactions" model="ir.actions.act_window">
      <field name="name">Carbon Ledger</field>
      <field name="res_model">ecosphere.carbon.transaction</field>
      <field name="view_mode">tree,form</field>
    </record>

    <record id="action_environmental_goals" model="ir.actions.act_window">
      <field name="name">Environmental Goals</field>
      <field name="res_model">ecosphere.environmental.goal</field>
      <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu Links -->
    <menuitem id="menu_carbon_transactions"
              name="Carbon Ledger"
              parent="menu_ecosphere_environmental"
              action="action_carbon_transactions"
              sequence="10"/>

    <menuitem id="menu_environmental_goals"
              name="Environmental Goals"
              parent="menu_ecosphere_environmental"
              action="action_environmental_goals"
              sequence="20"/>
  </data>
</odoo>
