<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Department Score List View -->
    <record id="view_department_score_tree" model="ir.ui.view">
      <field name="name">ecosphere.department.score.tree</field>
      <field name="model">ecosphere.department.score</field>
      <field name="arch" type="xml">
        <tree string="Department ESG Scores" create="false" edit="false">
          <field name="department_id"/>
          <field name="period_date"/>
          <field name="esg_score" widget="progressbar"/>
          <field name="environmental_score"/>
          <field name="social_score"/>
          <field name="governance_score"/>
          <field name="carbon_emission_kg"/>
        </tree>
      </field>
    </record>

    <!-- Department Score Kanban View -->
    <record id="view_department_score_kanban" model="ir.ui.view">
      <field name="name">ecosphere.department.score.kanban</field>
      <field name="model">ecosphere.department.score</field>
      <field name="arch" type="xml">
        <kanban class="o_kanban_mobile" create="false">
          <field name="department_id"/>
          <field name="period_date"/>
          <field name="esg_score"/>
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_global_click">
                <div class="oe_kanban_details">
                  <strong class="o_kanban_record_title"><field name="department_id"/></strong>
                  <div>ESG Impact Score: <t t-esc="record.esg_score.value"/>%</div>
                  <div>Period: <field name="period_date"/></div>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <!-- Action for Dashboard -->
    <record id="action_ecosphere_dashboard" model="ir.actions.act_window">
      <field name="name">ESG Overview Dashboard</field>
      <field name="res_model">ecosphere.department.score</field>
      <field name="view_mode">tree,kanban</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          Welcome to EcoSphere AI Overview!
        </p>
        <p>
          ESG indices will start appearing here as department telemetry logs.
        </p>
      </field>
    </record>

    <!-- Dashboard Menu Link -->
    <menuitem id="menu_ecosphere_dashboard_link"
              name="ESG Overview"
              parent="menu_ecosphere_dashboard"
              action="action_ecosphere_dashboard"
              sequence="10"/>
  </data>
</odoo>
