<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Report Action: Carbon Ledger Report -->
    <record id="action_report_carbon_ledger" model="ir.actions.report">
      <field name="name">Carbon Ledger PDF Report</field>
      <field name="model">ecosphere.carbon.transaction</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">ecosphere_ai.report_carbon_ledger_template</field>
      <field name="report_file">ecosphere_ai.report_carbon_ledger_template</field>
      <field name="binding_model_id" ref="model_ecosphere_carbon_transaction"/>
      <field name="binding_type">report</field>
    </record>

    <!-- QWeb PDF Template for Carbon Ledger Report -->
    <template id="report_carbon_ledger_template">
      <t t-call="web.html_container">
        <t t-call="web.external_layout">
          <div class="page" style="font-family: 'Inter', sans-serif;">
            <div style="border-bottom: 2px solid #10b981; padding-bottom: 10px; margin-bottom: 20px;">
              <h2 style="color: #065f46; margin: 0;">EcoSphere AI — Carbon Accounting Ledger</h2>
              <span style="font-size: 12px; color: #6b7280;">Generated on: <span t-esc="datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')"/></span>
            </div>

            <table class="table table-sm table-striped" style="width: 100%; border-collapse: collapse; font-size: 13px;">
              <thead>
                <tr style="background-color: #f1f5f9; border-bottom: 1px solid #cbd5e1;">
                  <th style="padding: 8px; text-align: left;">Reference</th>
                  <th style="padding: 8px; text-align: left;">Date</th>
                  <th style="padding: 8px; text-align: left;">Department</th>
                  <th style="padding: 8px; text-align: left;">Emission Source</th>
                  <th style="padding: 8px; text-align: right;">Quantity</th>
                  <th style="padding: 8px; text-align: right;">CO₂e (kg)</th>
                  <th style="padding: 8px; text-align: right;">CO₂e (tonnes)</th>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="docs" t-as="doc">
                  <tr style="border-bottom: 1px solid #e2e8f0;">
                    <td style="padding: 8px;"><span t-field="doc.name"/></td>
                    <td style="padding: 8px;"><span t-field="doc.transaction_date"/></td>
                    <td style="padding: 8px;"><span t-field="doc.department_id.name"/></td>
                    <td style="padding: 8px;"><span t-field="doc.emission_factor_id.name"/></td>
                    <td style="padding: 8px; text-align: right;"><span t-field="doc.quantity"/> <span t-field="doc.unit"/></td>
                    <td style="padding: 8px; text-align: right;"><span t-field="doc.co2_kg"/></td>
                    <td style="padding: 8px; text-align: right;"><span t-field="doc.co2_tonnes"/></td>
                  </tr>
                </t>
              </tbody>
            </table>

            <div style="margin-top: 30px; text-align: right; font-size: 14px; font-weight: bold; color: #065f46;">
              Total Carbon Footprint: <span t-esc="sum(docs.mapped('co2_tonnes'))"/> Tonnes CO₂e
            </div>
          </div>
        </t>
      </t>
    </template>
  </data>
</odoo>
