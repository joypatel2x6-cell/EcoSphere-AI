<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <!-- User Notification Rule: Users can only see their own notifications -->
    <record id="rule_ecosphere_notification_user" model="ir.rule">
      <field name="name">EcoSphere Notification: Personal Only</field>
      <field name="model_id" ref="model_ecosphere_notification"/>
      <field name="domain_force">[('user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_ecosphere_employee'))]"/>
    </record>

    <!-- Challenge Participation Rule: Employees see only their own challenge participations -->
    <record id="rule_ecosphere_challenge_participation_employee" model="ir.rule">
      <field name="name">EcoSphere Challenge Participation: Personal Only</field>
      <field name="model_id" ref="model_ecosphere_challenge_participation"/>
      <field name="domain_force">[('user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_ecosphere_employee'))]"/>
    </record>

    <!-- Department Manager Carbon Transaction Rule: Department managers can see transactions in their department -->
    <record id="rule_ecosphere_carbon_transaction_dept_manager" model="ir.rule">
      <field name="name">EcoSphere Carbon Transaction: Department Only</field>
      <field name="model_id" ref="model_ecosphere_carbon_transaction"/>
      <field name="domain_force">['|', ('department_id', '=', user.department_id.id), ('user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_ecosphere_dept_manager'))]"/>
    </record>

    <!-- ESG Manager Carbon Transaction Rule: ESG Managers can see all carbon transactions -->
    <record id="rule_ecosphere_carbon_transaction_esg_manager" model="ir.rule">
      <field name="name">EcoSphere Carbon Transaction: All access</field>
      <field name="model_id" ref="model_ecosphere_carbon_transaction"/>
      <field name="domain_force">[(1, '=', 1)]</field>
      <field name="groups" eval="[(4, ref('group_ecosphere_manager'))]"/>
    </record>
  </data>
</odoo>
